PORT=3000

# openai | replicate
AI_PROVIDER=openai

# Replicate (when AI_PROVIDER=replicate)
REPLICATE_API_TOKEN=r8_your-token-here

# OpenAI (when AI_PROVIDER=openai) — uses gpt-image-1.5 via images.edit + your upload
OPENAI_API_KEY=sk-your-key-here
# Optional; default is gpt-image-1.5
# OPENAI_IMAGE_MODEL=gpt-image-1.5
