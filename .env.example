PORT=3000

# openai | replicate
AI_PROVIDER=openai

# Replicate (when AI_PROVIDER=replicate)
REPLICATE_API_TOKEN=r8_your-token-here

# OpenAI (when AI_PROVIDER=openai) — uses gpt-image-1.5 via images.edit + your upload
OPENAI_API_KEY=sk-your-key-here
# Optional; default is gpt-image-1.5
# OPENAI_IMAGE_MODEL=gpt-image-1.5

# Hairstyle feature: openai | gemini  (defaults to openai)
HAIRSTYLE_PROVIDER=openai

# Gemini (when HAIRSTYLE_PROVIDER=gemini)
# GEMINI_API_KEY=your-gemini-key-here
# Optional; default is gemini-2.0-flash-exp
# GEMINI_IMAGE_MODEL=gemini-2.0-flash-exp
